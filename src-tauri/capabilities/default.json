{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "opener:default",
    "notification:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://192.168.*" },
        { "url": "http://10.*" },
        { "url": "http://172.16.*" },
        { "url": "https://api.polar.sh/**" },
        { "url": "https://sandbox-api.polar.sh/**" }
      ]
    }
  ]
}
